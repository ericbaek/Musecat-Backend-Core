# Runtime mode and persistent PocketBase data directory.
APP_ENV=development
PB_DATA_DIR=./pb_data

# Set these only when using the corresponding geocoding provider.
GOOGLE_MAPS_API_KEY=
KAKAO_REST_API_KEY=

# Optional protection for the bundled OpenAPI documentation routes.
DOCS_BASIC_AUTH_USER=
DOCS_BASIC_AUTH_PASS=
